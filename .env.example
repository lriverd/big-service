PORT=8080
ENVIRONMENT=development
FIREBASE_PROJECT_ID=your-firebase-project-id

# Contenido completo del service account JSON en UNA SOLA LÍNEA.
# Descárgalo en Firebase Console → Project Settings → Service Accounts → Generate new private key.
# Antes de pegar en Render: cat service-account.json | tr -d '\n'
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"..."}

# Web Client ID de Google Cloud Console (OAuth 2.0 → tipo Web).
# Requerido para validar el idToken que envía google_sign_in desde Android/iOS.
# También debe pasarse al compilar la app: --dart-define=GOOGLE_CLIENT_ID=<valor>
GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

JWT_SECRET=your-strong-jwt-secret-min-32-chars
JWT_EXPIRY_MINUTES=60
RATE_LIMIT_PER_MIN=100
ALLOWED_ORIGINS=*
LOG_LEVEL=info

# Habilitar registro de usuarios con email/password (false por defecto)
REGISTRATION_ENABLED=false

